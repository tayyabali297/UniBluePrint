# ============================================================
# UniBluePrint - N8N Schedule Booking Workflow
# Environment Variables Template
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# CLAUDE API (Anthropic)
# Get your key at: https://console.anthropic.com/
# ------------------------------------------------------------
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use (update when newer models are available)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens for schedule generation (4096 recommended)
CLAUDE_MAX_TOKENS=4096

# ------------------------------------------------------------
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# ------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ------------------------------------------------------------
# EMAIL (SMTP)
# Option A: SendGrid SMTP
#   Host: smtp.sendgrid.net | Port: 587 | User: apikey
# Option B: Resend SMTP
#   Host: smtp.resend.com | Port: 465 | User: resend
# Option C: Gmail (for development only)
#   Host: smtp.gmail.com | Port: 587 | User: your@gmail.com
# ------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_SECURE=false

# Sender email address (must be verified with your email provider)
FROM_EMAIL=schedules@unibluprint.ie
FROM_NAME=UniBluePrint Schedules

# ------------------------------------------------------------
# SLACK (Internal Notifications)
# Create an Incoming Webhook at:
# https://api.slack.com/messaging/webhooks
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_WITH_YOUR_SLACK_WEBHOOK_PATH

# ------------------------------------------------------------
# GOOGLE CALENDAR (Optional)
# Required only if using the Google Calendar sync node.
# Set up OAuth2 credentials at:
# https://console.cloud.google.com/apis/credentials
# Then configure in N8N Credentials.
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-n8n-instance.com/rest/oauth2-credential/callback

# ------------------------------------------------------------
# N8N INSTANCE
# ------------------------------------------------------------
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://your-n8n-instance.com/
WEBHOOK_URL=https://your-n8n-instance.com/

# N8N encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Basic auth for N8N UI (optional but recommended for production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-strong-password

# ------------------------------------------------------------
# WORKFLOW CONFIGURATION
# ------------------------------------------------------------
# Maximum retry attempts for Claude API calls
CLAUDE_MAX_RETRIES=3

# Retry delay in milliseconds (doubles on each retry)
CLAUDE_RETRY_DELAY_MS=2000

# Email send timeout in milliseconds
EMAIL_TIMEOUT_MS=30000

# Maximum concurrent workflow executions
N8N_DEFAULT_CONCURRENCY=10

# Timezone for scheduling (IANA timezone name)
WORKFLOW_TIMEZONE=Europe/Dublin

# ------------------------------------------------------------
# TYPEFORM (if using Typeform for form collection)
# Get your token at: https://admin.typeform.com/account/tokens
# ------------------------------------------------------------
TYPEFORM_API_TOKEN=tfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TYPEFORM_FORM_ID=your-form-id

# ------------------------------------------------------------
# DEVELOPMENT / DEBUG
# ------------------------------------------------------------
# Set to 'true' to log full Claude prompts and responses
DEBUG_CLAUDE_PROMPTS=false

# Set to 'true' to skip actual email sending (log only)
DEBUG_SKIP_EMAIL=false

# Set to 'true' to use mock Claude responses for testing
DEBUG_MOCK_CLAUDE=false

# Test email address (all emails go here when DEBUG_MODE=true)
DEBUG_EMAIL_RECIPIENT=developer@unibluprint.ie
